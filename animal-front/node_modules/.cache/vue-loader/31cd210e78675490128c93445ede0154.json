{"remainingRequest":"D:\\BS\\animal-front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\BS\\animal-front\\src\\views\\Login.vue?vue&type=style&index=0&id=26084dc2&lang=css","dependencies":[{"path":"D:\\BS\\animal-front\\src\\views\\Login.vue","mtime":1772251628268},{"path":"D:\\BS\\animal-front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1772251499152},{"path":"D:\\BS\\animal-front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1772251612013},{"path":"D:\\BS\\animal-front\\node_modules\\postcss-loader\\src\\index.js","mtime":1772251579751},{"path":"D:\\BS\\animal-front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1772251468697},{"path":"D:\\BS\\animal-front\\node_modules\\vue-loader\\lib\\index.js","mtime":1772251611953}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:Ci53cmFwcGVyIHsKICBoZWlnaHQ6IDEwMHZoOwogIGJhY2tncm91bmQtaW1hZ2U6IGxpbmVhci1ncmFkaWVudCh0byBib3R0b20gcmlnaHQsICM0MTY5RTEgLCAJIzg3Q0VGQSk7CiAgb3ZlcmZsb3c6IGhpZGRlbjsKfQo="},{"version":3,"sources":["Login.vue"],"names":[],"mappings":";AAgHA;AACA;AACA;AACA;AACA","file":"Login.vue","sourceRoot":"src/views","sourcesContent":["<template>\n  <div class=\"wrapper\">\n    <div style=\"height: 60px; line-height: 60px; font-size: 20px; padding-left: 50px; color: white;\n      background-color: rgba(0,0,0,0.2)\">宠物领养系统</div>\n    <div style=\"margin: 150px auto; background-color: #fff; width: 350px; height: 300px; padding: 20px; border-radius: 10px\">\n      <div style=\"margin: 20px 0; text-align: center; font-size: 24px\"><b>登 录</b></div>\n      <el-form :model=\"user\" :rules=\"rules\" ref=\"userForm\">\n        <el-form-item prop=\"username\">\n          <el-input size=\"medium\" prefix-icon=\"el-icon-user\" v-model=\"user.username\"></el-input>\n        </el-form-item>\n        <el-form-item prop=\"password\">\n          <el-input size=\"medium\" prefix-icon=\"el-icon-lock\" show-password v-model=\"user.password\"></el-input>\n        </el-form-item>\n        <el-form-item style=\"margin: 10px 0; text-align: right\">\n          <el-button type=\"warning\" size=\"small\"  autocomplete=\"off\" @click=\"$router.push('/register')\">前往注册</el-button>\n          <el-button type=\"primary\" size=\"small\"  autocomplete=\"off\" @click=\"login\">登录</el-button>\n\n        </el-form-item>\n        <el-form-item style=\"margin: 10px 0; text-align: right\">\n          <el-button type=\"text\" size=\"mid\"  autocomplete=\"off\" @click=\"handlePass\">找回密码</el-button>\n\n        </el-form-item>\n\n      </el-form>\n\n    </div>\n\n\n    <el-dialog title=\"找回密码\" :visible.sync=\"dialogFormVisible\" width=\"30%\" >\n      <el-form label-width=\"100px\" size=\"small\">\n        <el-form-item label=\"用户名\">\n          <el-input v-model=\"pass.username\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n        <el-form-item label=\"手机号\">\n          <el-input v-model=\"pass.phone\" autocomplete=\"off\"></el-input>\n        </el-form-item>\n      </el-form>\n      <div slot=\"footer\" class=\"dialog-footer\">\n        <el-button @click=\"dialogFormVisible = false\">取 消</el-button>\n        <el-button type=\"primary\" @click=\"passwordBack\">重置密码</el-button>\n      </div>\n\n\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport {resetRouter, setRoutes} from \"@/router\";\n\nexport default {\n  name: \"Login\",\n  data() {\n    return {\n      user: {},\n      pass: {},\n      dialogFormVisible: false,\n      rules: {\n        username: [\n          { required: true, message: '请输入用户名', trigger: 'blur' },\n          { min: 3, max: 10, message: '长度在 3 到 5 个字符', trigger: 'blur' }\n        ],\n        password: [\n          { required: true, message: '请输入密码', trigger: 'blur' },\n          { min: 1, max: 20, message: '长度在 1 到 20 个字符', trigger: 'blur' }\n        ],\n      }\n    }\n  },\n  created() {\n    // 重置路由\n    resetRouter()\n  },\n  methods: {\n    login() {\n      this.$refs['userForm'].validate((valid) => {\n        if (valid) {  // 表单校验合法\n          this.request.post(\"/user/login\", this.user).then(res => {\n            if(res.code === '200') {\n              localStorage.setItem(\"user\", JSON.stringify(res.data))  // 存储用户信息到浏览器\n              localStorage.setItem(\"menus\", JSON.stringify(res.data.menus))  // 存储用户信息到浏览器\n\n              // 动态设置当前用户的路由\n              setRoutes()\n              this.$router.push(\"/front/home\")\n              this.$message.success(\"登录成功\")\n            } else {\n              this.$message.error(res.msg)\n            }\n          })\n        }\n      });\n    },\n    handlePass() {\n      this.dialogFormVisible = true\n      this.pass = {}\n    },\n    passwordBack() {\n      this.request.put(\"/user/reset\", this.pass).then(res => {\n        if (res.code === '200') {\n          this.$message.success(\"重置密码成功，新密码为：123，请尽快修改密码\")\n          this.dialogFormVisible = false\n        } else {\n          this.$message.error(res.msg)\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style>\n.wrapper {\n  height: 100vh;\n  background-image: linear-gradient(to bottom right, #4169E1 , \t#87CEFA);\n  overflow: hidden;\n}\n</style>\n"]}]}